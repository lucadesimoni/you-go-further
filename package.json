{
  "name": "you-go-further",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personalized Swiss sports nutrition recommendations for endurance athletes, tailored by goal and session.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
