{
  "name": "you-go-further",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [8787, 5173],
  "portsAttributes": {
    "8787": { "label": "You Go Further (app + API)", "onAutoForward": "openPreview", "visibility": "public" },
    "5173": { "label": "Vite dev server", "onAutoForward": "silent" }
  },
  "postCreateCommand": "npm install",
  "postAttachCommand": {
    "serve": "nohup npm run codespace > /tmp/ygf.log 2>&1 & echo 'You Go Further starting on port 8787 — see /tmp/ygf.log'"
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode", "vitest.explorer"],
      "settings": { "editor.formatOnSave": true }
    }
  },
  "remoteEnv": {
    "VITE_APP_ENV": "codespace"
  }
}
